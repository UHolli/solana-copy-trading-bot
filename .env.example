# Application
LOG_LEVEL=info

# Redis cache (optional — defaults to in-memory when disabled)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=website-cloner:
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_MAX_RETRIES=5
REDIS_DEFAULT_TTL_SECONDS=86400

# Docker / runtime ports (used by docker-compose)
PORT=3000
DEV_PORT=3001
